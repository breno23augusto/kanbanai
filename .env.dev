# KanbanAI — dev/test environment using the pi coding agent as harness.
# Source this file before `kanbanai serve` (or use scripts/run-dev.sh).
# All KANBANAI_* vars are read by config/loader.go via viper.

# --- Server / persistence ---
export KANBANAI_SERVER_PORT=18400
export KANBANAI_SERVER_HOST=0.0.0.0
export KANBANAI_DB_PATH=./data/kanbanai.db
export KANBANAI_DB_MIGRATION_DIR=./internal/adapter/out/persistence/sqlite/migration_files
export KANBANAI_WEB_DIR=./web
export KANBANAI_LOG_LEVEL=info

# --- MCP server (dedicated port; SPEC §13.1) ---
export KANBANAI_MCP_PORT=18401

# --- Harness: pi (SDK-based wrapper) ---
# Command invoked as: <cmd> --model <model> --prompt <prompt>
export KANBANAI_HARNESS_DEFAULT_CMD=/home/breno/projects/kanbanai/scripts/pi-harness.sh
export KANBANAI_HARNESS_DEFAULT_MODEL=ollama/deepseek-v4-flash:cloud
# Per-attempt timeout (seconds). pi reasoning can take a while.
export KANBANAI_HARNESS_TIMEOUT_SEC=240
# Retry policy: backoff = 2*attempt seconds; stop after this many retries.
export KANBANAI_HARNESS_MAX_RETRIES=1

# --- Harness wrapper support (inherited by the spawned pi process) ---
# Base URL the wrapper uses to POST /tasks/:id/complete and bridge non-MCP flow.
export KANBANAI_API_URL=http://localhost:18400
# Optional: csv of pi tool names to enable (default: none -> pure reasoning).
#   Enable these to let pi actually inspect code and write artifacts in PI_HARNESS_CWD
#   (the Doing phase will produce real files instead of just a summary).
export PI_HARNESS_TOOLS=read,bash,grep,ls,write,edit
# Optional: working directory for the agent (default: inherits server cwd).
#   Artifacts produced by the harness land here.
export PI_HARNESS_CWD=/home/breno/projects/kanbanai/workspace
